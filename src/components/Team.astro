---
const members = [
  {
    seed: 'marco-ferretti',
    name: 'Marco Ferretti',
    role: 'Fondateur & carreleur',
    since: '8 ans de métier',
    quote: "J'ai des belles réalisations, des trucs avec de la mosaïque faite main… je veux que ça se voie.",
  },
  {
    seed: 'ferretti-employe',
    name: 'Notre nouvelle recrue',
    role: 'Carreleur',
    since: 'Équipe depuis 2025',
    quote: "Trois personnes, une seule façon de travailler : bien.",
  },
]
---

<section id="equipe" class="team">
  <div class="team__inner">
    <div class="team__header">
      <span class="section-tag">L'équipe</span>
      <h2>Derrière chaque chantier,<br/>un artisan qui s'engage.</h2>
      <p>
        Ferretti Carrelage c'est une petite équipe — trois personnes,
        un seul standard de qualité. Marco supervise personnellement
        chaque réalisation.
      </p>
    </div>

    <div class="team__grid">
      {members.map(member => (
        <article class="team__card">
          <div class="team__card-img">
            <img
              src={`https://picsum.photos/seed/${member.seed}/400/400`}
              alt={`${member.name} — Ferretti Carrelage`}
              width="400"
              height="400"
              loading="lazy"
            />
          </div>
          <div class="team__card-body">
            <div class="team__card-meta">
              <h3>{member.name}</h3>
              <span class="team__card-role">{member.role}</span>
              <span class="team__card-since">{member.since}</span>
            </div>
            <blockquote class="team__card-quote">
              "{member.quote}"
            </blockquote>
          </div>
        </article>
      ))}
    </div>

    <div class="team__zone">
      <div class="team__zone-label">Zone d'intervention</div>
      <div class="team__zone-cities">
        <span>Montpellier</span>
        <span class="team__zone-sep">—</span>
        <span>Sète</span>
        <span class="team__zone-sep">—</span>
        <span>Béziers</span>
        <span class="team__zone-sep">—</span>
        <span>Agde</span>
        <span class="team__zone-sep">—</span>
        <span>Pézenas</span>
        <span class="team__zone-sep">—</span>
        <span>Hérault</span>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.team {
  background: $color-bg-alt;
  padding-block: $section-padding;

  &__inner {
    @include container;
  }

  &__header {
    max-width: 600px;
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;

    h2 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    p {
      color: $color-text-muted;
      line-height: 1.75;
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;

    @include respond-to('md') {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  &__card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    background: $color-bg-card;
    border: 1px solid $color-border;
    border-radius: $radius-lg;
    overflow: hidden;
    box-shadow: $shadow-sm;

    @include respond-to('md') {
      flex-direction: row;
    }
  }

  &__card-img {
    flex-shrink: 0;
    width: 100%;

    @include respond-to('md') {
      width: 160px;
    }

    img {
      width: 100%;
      height: 220px;
      object-fit: cover;

      @include respond-to('md') {
        height: 100%;
      }
    }
  }

  &__card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    justify-content: center;
  }

  &__card-meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;

    h3 {
      font-size: 1.1rem;
      font-weight: 700;
      color: $color-text;
    }
  }

  &__card-role {
    font-size: 0.875rem;
    font-weight: 600;
    color: $color-accent;
  }

  &__card-since {
    font-size: 0.8rem;
    color: $color-text-subtle;
  }

  &__card-quote {
    margin: 0;
    font-size: 0.9rem;
    font-style: italic;
    color: $color-text-muted;
    line-height: 1.65;
    border-left: 3px solid $color-accent-bg;
    padding-left: 0.875rem;
  }

  &__zone {
    margin-top: 3.5rem;
    padding: 1.5rem 2rem;
    background: $color-bg-card;
    border: 1px solid $color-border;
    border-radius: $radius-md;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    align-items: center;
    text-align: center;
  }

  &__zone-label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: $color-text-subtle;
  }

  &__zone-cities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 0.75rem;
    justify-content: center;
    align-items: center;
    font-size: 0.975rem;
    font-weight: 600;
    color: $color-text;
  }

  &__zone-sep {
    color: $color-accent;
    font-weight: 400;
  }
}
</style>
