---
import { site } from '@/config/site'
---

<section id="equipe" class="team">
  <div class="team__photo-panel">
    <img
      src="https://picsum.photos/seed/marco-ferretti/700/900"
      alt="Marco Ferretti — Ferretti Carrelage"
      width="700"
      height="900"
      loading="lazy"
    />
  </div>

  <div class="team__content">
    <p class="team__label">L'artisan</p>

    <h2 class="team__name">Marco Ferretti</h2>
    <p class="team__role">Fondateur & carreleur · 8 ans de métier</p>

    <blockquote class="team__quote">
      "J'ai pas besoin de trucs compliqués. Juste : qui je suis, ce que je fais,
      mes photos, et un moyen de me contacter. Les clients, ils voient le travail
      et ils savent."
    </blockquote>

    <div class="team__facts">
      <div class="team__fact">
        <strong>3</strong>
        <span>personnes dans l'équipe</span>
      </div>
      <div class="team__fact">
        <strong>8 ans</strong>
        <span>d'expérience terrain</span>
      </div>
      <div class="team__fact">
        <strong>100%</strong>
        <span>chantiers dans l'Hérault</span>
      </div>
    </div>

    <div class="team__zone">
      <p class="team__zone-label">Zone d'intervention</p>
      <p class="team__zone-cities">
        Montpellier · Sète · Béziers · Agde · Pézenas · Hérault
      </p>
    </div>

    <a href="#contact" class="btn btn--primary">Parler à Marco</a>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.team {
  display: grid;
  grid-template-columns: 1fr;

  @include respond-to('lg') {
    grid-template-columns: 420px 1fr;
    min-height: 640px;
  }

  &__photo-panel {
    position: relative;
    overflow: hidden;
    min-height: 60vw;
    background: $color-bg-alt;

    @include respond-to('lg') {
      min-height: unset;
    }

    img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
  }

  &__content {
    background: $color-accent-bg;
    padding: clamp(3rem, 8vw, 5rem) clamp(2rem, 6vw, 4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1.75rem;

    @include respond-to('lg') {
      padding-right: max(2.5rem, calc((100vw - #{$container-max}) / 2 + 2.5rem));
    }
  }

  &__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: $color-accent;
  }

  &__name {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: $color-text;
    line-height: 1.1;
  }

  &__role {
    font-size: 0.9rem;
    font-weight: 500;
    color: $color-text-muted;
    margin-top: -1rem;
  }

  &__quote {
    margin: 0;
    font-size: clamp(0.95rem, 1.8vw, 1.1rem);
    font-style: italic;
    color: $color-text-muted;
    line-height: 1.75;
    border-left: 3px solid $color-accent;
    padding-left: 1.25rem;
    max-width: 480px;
  }

  &__facts {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  &__fact {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;

    strong {
      font-size: 1.75rem;
      font-weight: 800;
      color: $color-accent;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    span {
      font-size: 0.75rem;
      color: $color-text-muted;
      font-weight: 500;
    }
  }

  &__zone {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-top: 0.5rem;
    border-top: 1px solid $color-border;
  }

  &__zone-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: $color-text-subtle;
  }

  &__zone-cities {
    font-size: 0.875rem;
    font-weight: 600;
    color: $color-text;
  }
}
</style>
