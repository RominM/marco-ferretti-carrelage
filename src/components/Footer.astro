---
import { site } from '@/config/site'
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer__top">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label={site.fullName}>
        <svg viewBox="0 0 40 40" width="30" height="30" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
          <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
          <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
          <polygon points="20,20 30,30 20,40 10,30" fill="rgba(255,255,255,0.12)"/>
        </svg>
        <span>Ferretti Carrelage</span>
      </a>
      <p>Artisan carreleur dans l'Hérault.<br/>Mosaïque, faïence, carrelage sur mesure.</p>
    </div>

    <nav class="footer__nav" aria-label="Plan du site">
      <strong>Navigation</strong>
      <a href="#services">Services</a>
      <a href="#projets">Réalisations</a>
      <a href="#equipe">L'équipe</a>
      <a href="#contact">Devis gratuit</a>
    </nav>

    <div class="footer__contact">
      <strong>Contact</strong>
      <p>Villeneuve-lès-Béziers (34420)</p>
      <p>Lun – Ven · 8h30 – 19h00</p>
      <p>Réponse sous 48h</p>
    </div>

    <div class="footer__zone">
      <strong>Zone d'intervention</strong>
      <p>Montpellier · Sète · Béziers<br/>Agde · Pézenas · Hérault</p>
    </div>
  </div>

  <div class="footer__bottom">
    <span>© {year} Ferretti Carrelage</span>
    <span>Site par <a href="https://mgl-studio.fr" target="_blank" rel="noopener">MGL Studio</a></span>
  </div>
</footer>

<style lang="scss">
@use '../styles/foundations' as *;

.footer {
  background: #141210;
  color: rgba(255, 255, 255, 0.5);

  &__top {
    @include container;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3.5rem;
    padding-bottom: 3rem;

    @include respond-to('md') {
      grid-template-columns: 1fr 1fr;
    }

    @include respond-to('lg') {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  &__brand {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;

    p {
      font-size: 0.85rem;
      line-height: 1.75;
      max-width: 240px;
    }
  }

  &__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
  }

  &__nav,
  &__contact,
  &__zone {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;

    strong {
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: white;
      margin-bottom: 0.25rem;
    }

    p {
      font-size: 0.85rem;
      line-height: 1.7;
    }
  }

  &__nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.5);
    transition: color $transition;

    &:hover { color: $color-accent; }
  }

  &__bottom {
    @include container;
    @include flex-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);

    a {
      color: rgba(255, 255, 255, 0.45);
      transition: color $transition;

      &:hover { color: $color-accent; }
    }
  }
}
</style>
