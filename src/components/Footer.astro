---
import { site } from '@/config/site'

const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <a href="/" class="footer__logo" aria-label={site.fullName}>
        <svg viewBox="0 0 40 40" width="32" height="32" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
          <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
          <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
          <polygon points="20,20 30,30 20,40 10,30" fill="rgba(255,255,255,0.15)"/>
        </svg>
        <span>Ferretti Carrelage</span>
      </a>
      <p>Artisan carreleur dans l'Hérault.<br/>Mosaïque, faïence, carrelage sur-mesure.</p>
    </div>

    <nav class="footer__nav" aria-label="Navigation secondaire">
      <strong>Navigation</strong>
      <a href="#services">Services</a>
      <a href="#projets">Réalisations</a>
      <a href="#equipe">L'équipe</a>
      <a href="#contact">Devis gratuit</a>
    </nav>

    <div class="footer__contact">
      <strong>Contact</strong>
      <div class="footer__contact-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M7 1a3 3 0 013 3c0 3-3 7-3 7S4 7 4 4a3 3 0 013-3z" stroke="currentColor" stroke-width="1.25"/>
          <circle cx="7" cy="4" r="1.25" fill="currentColor"/>
        </svg>
        <span>Villeneuve-lès-Béziers (34420)</span>
      </div>
      <div class="footer__contact-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="3" width="12" height="8" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
          <path d="M1 4l6 4 6-4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        </svg>
        <span>Sur devis · réponse sous 48h</span>
      </div>
      <div class="footer__contact-item">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <rect x="1" y="2" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.25"/>
          <path d="M1 6h12M4 2v4M10 2v4" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/>
        </svg>
        <span>Lun–Ven · 8h30 – 19h00</span>
      </div>
    </div>

    <div class="footer__zone">
      <strong>Zone d'intervention</strong>
      <p>Montpellier · Sète · Béziers<br/>Agde · Pézenas · Hérault</p>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__bottom-inner">
      <span>© {year} Ferretti Carrelage · Tous droits réservés</span>
      <span>Site réalisé par <a href="https://mgl-studio.fr" target="_blank" rel="noopener">MGL Studio</a></span>
    </div>
  </div>
</footer>

<style lang="scss">
@use '../styles/foundations' as *;

.footer {
  background: $color-text;
  color: rgba(255, 255, 255, 0.75);

  &__inner {
    @include container;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-top: 3.5rem;
    padding-bottom: 3rem;

    @include respond-to('md') {
      grid-template-columns: 1fr 1fr;
    }

    @include respond-to('lg') {
      grid-template-columns: 2fr 1fr 1fr 1fr;
    }
  }

  &__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;

    p {
      font-size: 0.875rem;
      line-height: 1.7;
      max-width: 260px;
    }
  }

  &__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 0.975rem;
    color: white;
  }

  &__nav,
  &__contact,
  &__zone {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    strong {
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: white;
      margin-bottom: 0.25rem;
    }
  }

  &__nav a {
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.65);
    transition: color $transition;

    &:hover {
      color: $color-accent;
    }
  }

  &__contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.65);
  }

  &__zone p {
    font-size: 0.875rem;
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.65);
  }

  &__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  &__bottom-inner {
    @include container;
    @include flex-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-top: 1.25rem;
    padding-bottom: 1.25rem;
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.4);

    a {
      color: rgba(255, 255, 255, 0.6);
      transition: color $transition;

      &:hover {
        color: $color-accent;
      }
    }
  }
}
</style>
