---
const services = [
  {
    num: '01',
    title: 'Pose de carrelage',
    description: 'Sol intérieur et extérieur, grès cérame, terrasse, piscine. Pose droite, diagonale ou en biais — chaque chantier est mesuré et préparé avec soin.',
    featured: false,
  },
  {
    num: '02',
    title: 'Faïence murale',
    description: 'Salle de bain, douche, cuisine, crédence. Pose précise au millimètre pour un résultat propre, durable et imperméable.',
    featured: false,
  },
  {
    num: '03',
    title: 'Mosaïque faite main',
    description: "La spécialité de Marco. Chaque tesselle posée à la main pour des réalisations uniques : douche italienne, niche décorative, crédence sur-mesure. Haut de gamme, sans compromis.",
    featured: true,
  },
  {
    num: '04',
    title: 'Rénovation salle de bain',
    description: "Dépose de l'ancien revêtement, préparation des supports, pose complète. Marco prend en charge l'intégralité du carrelage de votre salle de bain, de A à Z.",
    featured: false,
  },
]
---

<section id="services" class="services">
  <div class="services__inner">
    <header class="services__header">
      <p class="services__label">Services</p>
      <h2>Ce que je fais,<br/>et ce que je fais bien.</h2>
    </header>

    <ol class="services__list">
      {services.map(s => (
        <li class:list={['services__item', { 'services__item--featured': s.featured }]}>
          <span class="services__num" aria-hidden="true">{s.num}</span>
          <div class="services__body">
            <h3 class="services__title">
              {s.title}
              {s.featured && <span class="services__badge">Signature</span>}
            </h3>
            <p class="services__desc">{s.description}</p>
          </div>
          {!s.featured && (
            <svg class="services__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
              <path d="M4 10h12M11 5l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          )}
        </li>
      ))}
    </ol>

    <div class="services__cta">
      <a href="#contact" class="btn btn--primary">Demander un devis gratuit</a>
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.services {
  background: $color-bg;
  padding-block: $section-padding;

  &__inner {
    @include container;
  }

  &__header {
    margin-bottom: 3.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;

    h2 {
      font-size: clamp(1.875rem, 4.5vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      max-width: 480px;
    }
  }

  &__label {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: $color-accent;
  }

  &__list {
    list-style: none;
    padding: 0;
    margin: 0;
    border-top: 1px solid $color-border;
  }

  &__item {
    display: grid;
    grid-template-columns: 3rem 1fr auto;
    gap: 1.5rem 2rem;
    align-items: center;
    padding-block: 2rem;
    border-bottom: 1px solid $color-border;
    transition: background $transition;

    @include respond-to('md') {
      grid-template-columns: 4rem 1fr auto;
      padding-block: 2.5rem;
    }

    &:hover:not(&--featured) {
      background: $color-bg-alt;
      margin-inline: -1.5rem;
      padding-inline: 1.5rem;
      border-radius: $radius-sm;
    }

    &--featured {
      background: $color-accent;
      border-bottom-color: transparent;
      margin-inline: -1.5rem;
      padding-inline: 1.5rem;
      border-radius: $radius-md;
      color: white;
      box-shadow: $shadow-md;

      @include respond-to('md') {
        margin-inline: -2.5rem;
        padding-inline: 2.5rem;
      }

      .services__num {
        color: rgba(255, 255, 255, 0.25);
      }

      .services__title {
        color: white;
      }

      .services__desc {
        color: rgba(255, 255, 255, 0.8);
      }
    }
  }

  &__num {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: $color-accent;
    opacity: 0.18;
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  &__body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  &__title {
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    font-weight: 700;
    color: $color-text;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  &__badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: $color-accent;
    background: white;
    padding: 0.2rem 0.6rem;
    border-radius: $radius-pill;
  }

  &__desc {
    font-size: 0.925rem;
    color: $color-text-muted;
    line-height: 1.75;
    max-width: 560px;
  }

  &__arrow {
    color: $color-text-subtle;
    flex-shrink: 0;
    transition: transform $transition, color $transition;

    .services__item:hover & {
      transform: translateX(4px);
      color: $color-accent;
    }
  }

  &__cta {
    margin-top: 3rem;
  }
}
</style>
