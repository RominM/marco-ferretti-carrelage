---
import { site } from '@/config/site'
---

<section class="hero">
  <div class="hero__content">
    <span class="hero__tag">Artisan carreleur dans l'Hérault</span>

    <h1 class="hero__title">
      Votre intérieur entre<br/>
      <em>de bonnes mains.</em>
    </h1>

    <p class="hero__sub">
      Depuis 8 ans, Marco Ferretti pose du carrelage, de la faïence
      et de la mosaïque sur mesure sur Montpellier, Sète et Béziers.
    </p>

    <div class="hero__cta">
      <a href="#contact" class="btn btn--primary">Demander un devis gratuit</a>
      <a href="#projets" class="btn btn--secondary">Voir les réalisations</a>
    </div>

    <ul class="hero__trust" role="list">
      <li>8 ans d'expérience</li>
      <li>Mosaïque faite main</li>
      <li>Devis gratuit en 48h</li>
    </ul>
  </div>

  <div class="hero__visual">
    <img
      src="https://picsum.photos/seed/ferretti-main/900/1100"
      alt="Réalisation Ferretti Carrelage — salle de bain haut de gamme"
      width="900"
      height="1100"
      loading="eager"
    />
    <div class="hero__visual-badge" aria-hidden="true">
      <svg viewBox="0 0 40 40" width="40" height="40" xmlns="http://www.w3.org/2000/svg">
        <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
        <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
        <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
        <polygon points="20,20 30,30 20,40 10,30" fill="rgba(255,255,255,0.3)"/>
      </svg>
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.hero {
  display: grid;
  grid-template-columns: 1fr;
  min-height: calc(100svh - 4rem);

  @include respond-to('lg') {
    grid-template-columns: 55% 45%;
  }

  &__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 2rem;
    padding: clamp(3rem, 8vw, 5rem) clamp(1.5rem, 5vw, 2.5rem);
    padding-right: clamp(2rem, 5vw, 4rem);

    @include respond-to('lg') {
      padding-left: max(2.5rem, calc((100vw - #{$container-max}) / 2 + 2.5rem));
    }
  }

  &__tag {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: $color-accent;
    width: fit-content;

    &::before {
      content: '';
      display: inline-block;
      width: 2rem;
      height: 2px;
      background: $color-accent;
      margin-right: 0.75rem;
      flex-shrink: 0;
    }
  }

  &__title {
    font-size: clamp(2.25rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.03em;
    color: $color-text;
    max-width: 520px;

    em {
      font-style: normal;
      color: $color-accent;
    }
  }

  &__sub {
    font-size: clamp(1rem, 1.8vw, 1.1rem);
    color: $color-text-muted;
    line-height: 1.75;
    max-width: 440px;
  }

  &__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
  }

  &__trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    border-top: 1px solid $color-border;
    padding-top: 1.5rem;

    li {
      font-size: 0.8rem;
      font-weight: 600;
      color: $color-text-subtle;
      letter-spacing: 0.03em;
      text-transform: uppercase;

      &:not(:last-child)::after {
        content: '·';
        margin-inline: 0.75rem;
        color: $color-accent;
      }
    }
  }

  &__visual {
    position: relative;
    overflow: hidden;
    min-height: 55vw;

    @include respond-to('lg') {
      min-height: unset;
    }

    img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  &__visual-badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(6px);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: $radius-md;
    padding: 0.75rem;
    display: flex;
  }
}
</style>
