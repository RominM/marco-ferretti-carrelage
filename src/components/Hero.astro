---
import { site } from '@/config/site'
---

<section class="hero">
  <div class="hero__inner">
    <div class="hero__content">
      <span class="hero__tag">Artisan carreleur dans l'Hérault</span>

      <h1 class="hero__title">
        Votre intérieur entre
        <em>de bonnes mains.</em>
      </h1>

      <p class="hero__subtitle">
        Marco Ferretti pose du carrelage, de la faïence et de la mosaïque
        sur mesure depuis 8 ans. Montpellier, Sète, Béziers et alentours.
      </p>

      <div class="hero__cta">
        <a href="#contact" class="btn btn--primary">Demander un devis gratuit</a>
        <a href="#projets" class="btn btn--secondary">Voir les réalisations</a>
      </div>

      <ul class="hero__trust">
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="8" fill="#E0621C" fill-opacity="0.15"/>
            <path d="M5 8l2 2 4-4" stroke="#E0621C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          8 ans d'expérience
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="8" fill="#E0621C" fill-opacity="0.15"/>
            <path d="M5 8l2 2 4-4" stroke="#E0621C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Mosaïque faite main
        </li>
        <li>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <circle cx="8" cy="8" r="8" fill="#E0621C" fill-opacity="0.15"/>
            <path d="M5 8l2 2 4-4" stroke="#E0621C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Devis gratuit en 48h
        </li>
      </ul>
    </div>

    <div class="hero__visual">
      <div class="hero__image-wrap">
        <img
          src="https://picsum.photos/seed/ferretti-hero/700/800"
          alt="Réalisation Ferretti Carrelage — salle de bain haut de gamme"
          width="700"
          height="800"
          loading="eager"
        />
      </div>
      <div class="hero__badge">
        <svg viewBox="0 0 40 40" width="28" height="28" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
          <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
          <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
          <polygon points="20,20 30,30 20,40 10,30" fill="white"/>
        </svg>
        <div>
          <strong>Ferretti Carrelage</strong>
          <span>Villeneuve-lès-Béziers</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.hero {
  background: $color-bg;
  padding-top: clamp(3rem, 8vw, 5rem);
  padding-bottom: clamp(3rem, 8vw, 5rem);
  overflow: hidden;

  &__inner {
    @include container;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;

    @include respond-to('lg') {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  &__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  &__tag {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: $color-accent;
    background: $color-accent-bg;
    padding: 0.35rem 0.875rem;
    border-radius: $radius-pill;
    width: fit-content;
  }

  &__title {
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: $color-text;

    em {
      font-style: normal;
      color: $color-accent;
    }
  }

  &__subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: $color-text-muted;
    line-height: 1.75;
    max-width: 480px;
  }

  &__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.875rem;
    align-items: center;
  }

  &__trust {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;

    li {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      font-weight: 500;
      color: $color-text-muted;
    }
  }

  &__visual {
    position: relative;
    display: flex;
    justify-content: center;

    @include respond-to('lg') {
      justify-content: flex-end;
    }
  }

  &__image-wrap {
    position: relative;
    width: 100%;
    max-width: 440px;
    border-radius: $radius-lg;
    overflow: hidden;
    box-shadow: $shadow-lg;

    img {
      width: 100%;
      height: auto;
      aspect-ratio: 7/8;
      object-fit: cover;
    }
  }

  &__badge {
    position: absolute;
    bottom: -1rem;
    left: -0.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: white;
    border: 1px solid $color-border;
    border-radius: $radius-md;
    padding: 0.75rem 1rem;
    box-shadow: $shadow-md;

    @include respond-to('lg') {
      left: -2rem;
    }

    div {
      display: flex;
      flex-direction: column;
      line-height: 1.3;
    }

    strong {
      font-size: 0.8rem;
      font-weight: 700;
      color: $color-text;
    }

    span {
      font-size: 0.7rem;
      color: $color-text-muted;
    }
  }
}
</style>
