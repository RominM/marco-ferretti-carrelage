---
import { site } from '@/config/site'
---

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo" aria-label={site.fullName}>
      <svg viewBox="0 0 40 40" width="34" height="34" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
        <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
        <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
        <polygon points="20,20 30,30 20,40 10,30" fill="white"/>
      </svg>
      <span>Ferretti Carrelage</span>
    </a>

    <nav class="nav__links" aria-label="Navigation principale">
      <a href="#services">Services</a>
      <a href="#projets">Réalisations</a>
      <a href="#equipe">L'équipe</a>
    </nav>

    <div class="nav__actions">
      <a href="#contact" class="btn btn--primary">Demander un devis</a>
    </div>

    <button class="nav__toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-mobile">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <div id="nav-mobile" class="nav__mobile" hidden>
    <nav aria-label="Navigation mobile">
      <a href="#services">Services</a>
      <a href="#projets">Réalisations</a>
      <a href="#equipe">L'équipe</a>
      <a href="#contact" class="btn btn--primary">Demander un devis</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('.nav__toggle')
  const mobile = document.getElementById('nav-mobile')

  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true'
    toggle.setAttribute('aria-expanded', String(!open))
    toggle.setAttribute('aria-label', open ? 'Ouvrir le menu' : 'Fermer le menu')
    if (mobile) mobile.hidden = open
  })

  mobile?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (mobile) mobile.hidden = true
      toggle?.setAttribute('aria-expanded', 'false')
      toggle?.setAttribute('aria-label', 'Ouvrir le menu')
    })
  })
</script>

<style lang="scss">
@use '../styles/foundations' as *;

.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(249, 248, 246, 0.96);
  backdrop-filter: blur(8px);
  border-bottom: 1px solid $color-border;

  &__inner {
    @include container;
    @include flex-between;
    height: 4rem;
    gap: 1.5rem;
  }

  &__logo {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    font-weight: 700;
    font-size: 0.975rem;
    color: $color-text;
    flex-shrink: 0;
  }

  &__links {
    display: none;
    align-items: center;
    gap: 2rem;

    @include respond-to('lg') {
      display: flex;
    }

    a {
      font-size: 0.875rem;
      font-weight: 500;
      color: $color-text-muted;
      transition: color $transition;

      &:hover { color: $color-accent; }
    }
  }

  &__actions {
    display: none;

    @include respond-to('lg') { display: block; }
  }

  &__toggle {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: 0.5rem;
    background: none;
    border: none;
    flex-shrink: 0;

    @include respond-to('lg') { display: none; }

    span {
      display: block;
      width: 20px;
      height: 2px;
      background: $color-text;
      border-radius: 2px;
      transition: all $transition;
    }
  }

  &__mobile {
    border-top: 1px solid $color-border;
    background: $color-bg;

    nav {
      @include container;
      display: flex;
      flex-direction: column;
      padding-top: 1rem;
      padding-bottom: 1.5rem;

      a:not(.btn) {
        padding: 0.75rem 0;
        font-weight: 500;
        color: $color-text;
        border-bottom: 1px solid $color-border;
        transition: color $transition;

        &:hover { color: $color-accent; }
      }

      .btn {
        margin-top: 1rem;
        align-self: flex-start;
      }
    }
  }
}
</style>
