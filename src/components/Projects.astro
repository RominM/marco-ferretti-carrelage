---
const projects = [
  {
    seed: 'fc-sdb1',
    label: 'Salle de bain — faïence grand format',
    tag: 'Faïence',
    location: 'Montpellier',
  },
  {
    seed: 'fc-mosaic1',
    label: 'Douche italienne — mosaïque faite main',
    tag: 'Mosaïque',
    location: 'Sète',
  },
  {
    seed: 'fc-sol1',
    label: 'Sol en grès cérame — terrasse extérieure',
    tag: 'Carrelage sol',
    location: 'Béziers',
  },
  {
    seed: 'fc-sdb2',
    label: 'Rénovation complète — salle de bain haut de gamme',
    tag: 'Rénovation',
    location: 'Montpellier',
  },
  {
    seed: 'fc-niche1',
    label: 'Niche décorative — mosaïque sur-mesure',
    tag: 'Mosaïque',
    location: 'Agde',
  },
  {
    seed: 'fc-cuisine1',
    label: 'Crédence cuisine — carreaux de ciment',
    tag: 'Faïence',
    location: 'Pézenas',
  },
]
---

<section id="projets" class="projects">
  <div class="projects__inner">
    <header class="projects__header">
      <h2>Des chantiers qui<br/>parlent d'eux-mêmes.</h2>
      <p>Chaque photo est un chantier réel, dans l'Hérault. Ce que vous voyez, c'est ce que vous obtenez.</p>
      <a href="#contact" class="btn btn--outline-light">Votre projet mérite le même soin</a>
    </header>

    <div class="projects__grid">
      {projects.map((p, i) => (
        <article class="projects__item">
          <img
            src={`https://picsum.photos/seed/${p.seed}/800/600`}
            alt={p.label}
            width="800"
            height="600"
            loading={i < 2 ? 'eager' : 'lazy'}
          />
          <div class="projects__overlay">
            <span class="projects__tag">{p.tag}</span>
            <div class="projects__meta">
              <p>{p.label}</p>
              <span>{p.location}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.projects {
  background: $color-text;
  padding-block: $section-padding;

  &__inner {
    @include container;
  }

  &__header {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-bottom: 3rem;
    max-width: 540px;

    h2 {
      font-size: clamp(1.875rem, 4.5vw, 3rem);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.03em;
      color: white;
    }

    p {
      color: rgba(255, 255, 255, 0.55);
      font-size: 0.975rem;
      line-height: 1.75;
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;

    @include respond-to('md') {
      grid-template-columns: repeat(3, 1fr);
    }

    // Grille irrégulière : large–étroit / étroit–large alternés
    @include respond-to('md') {
      :nth-child(1) { grid-column: span 2; }
      :nth-child(2) { grid-column: span 1; }
      :nth-child(3) { grid-column: span 1; }
      :nth-child(4) { grid-column: span 2; }
      :nth-child(5) { grid-column: span 2; }
      :nth-child(6) { grid-column: span 1; }
    }
  }

  &__item {
    position: relative;
    overflow: hidden;
    border-radius: $radius-sm;
    cursor: pointer;

    img {
      display: block;
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      transition: transform 0.45s ease;
      filter: brightness(0.85);
    }

    &:hover img {
      transform: scale(1.05);
      filter: brightness(0.7);
    }

    &:hover .projects__overlay {
      opacity: 1;
    }
  }

  &__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.25rem;
    background: linear-gradient(to bottom, transparent 40%, rgba(28, 25, 22, 0.85));
    opacity: 0.85;
    transition: opacity $transition;
  }

  &__tag {
    align-self: flex-start;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: white;
    background: $color-accent;
    padding: 0.25rem 0.625rem;
    border-radius: $radius-pill;
  }

  &__meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;

    p {
      font-size: 0.875rem;
      font-weight: 600;
      color: white;
      line-height: 1.4;
    }

    span {
      font-size: 0.75rem;
      color: rgba(255, 255, 255, 0.6);
    }
  }
}

.btn--outline-light {
  display: inline-flex;
  align-items: center;
  padding: 0.625rem 1.5rem;
  border-radius: $radius-pill;
  font-weight: 600;
  font-size: 0.875rem;
  border: 1.5px solid rgba(255, 255, 255, 0.3);
  color: rgba(255, 255, 255, 0.75);
  transition: all $transition;
  width: fit-content;

  &:hover {
    border-color: $color-accent;
    color: $color-accent;
  }
}
</style>
