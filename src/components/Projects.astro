---
const projects = [
  {
    seed: 'fc-sdb1',
    label: 'Salle de bain — faïence grand format',
    tag: 'Faïence',
    location: 'Montpellier',
  },
  {
    seed: 'fc-mosaic1',
    label: 'Douche italienne — mosaïque faite main',
    tag: 'Mosaïque',
    location: 'Sète',
  },
  {
    seed: 'fc-sol1',
    label: 'Sol en grès cérame — terrasse',
    tag: 'Carrelage sol',
    location: 'Béziers',
  },
  {
    seed: 'fc-sdb2',
    label: 'Rénovation complète salle de bain',
    tag: 'Rénovation',
    location: 'Montpellier',
  },
  {
    seed: 'fc-niche1',
    label: 'Niche décorative — mosaïque sur-mesure',
    tag: 'Mosaïque',
    location: 'Agde',
  },
  {
    seed: 'fc-cuisine1',
    label: 'Crédence cuisine — carreaux de ciment',
    tag: 'Faïence',
    location: 'Pézenas',
  },
]
---

<section id="projets" class="projects">
  <div class="projects__inner">
    <div class="projects__header">
      <span class="section-tag">Réalisations</span>
      <h2>Des chantiers qui parlent d'eux-mêmes.</h2>
      <p>
        Chaque photo est un chantier réel, dans l'Hérault.
        Ce que vous voyez, c'est ce que vous obtenez.
      </p>
    </div>

    <div class="projects__grid">
      {projects.map((project, i) => (
        <article class="projects__card">
          <div class="projects__card-img">
            <img
              src={`https://picsum.photos/seed/${project.seed}/600/450`}
              alt={project.label}
              width="600"
              height="450"
              loading={i < 3 ? 'eager' : 'lazy'}
            />
            <span class="projects__card-tag">{project.tag}</span>
          </div>
          <div class="projects__card-info">
            <span class="projects__card-location">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M6 1a3.5 3.5 0 013.5 3.5C9.5 7.5 6 11 6 11S2.5 7.5 2.5 4.5A3.5 3.5 0 016 1z" stroke="currentColor" stroke-width="1.25"/>
                <circle cx="6" cy="4.5" r="1.25" fill="currentColor"/>
              </svg>
              {project.location}
            </span>
            <p>{project.label}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="projects__cta">
      <a href="#contact" class="btn btn--outline">
        Votre projet ressemble à l'un de ceux-là ? Parlons-en.
      </a>
    </div>
  </div>
</section>

<style lang="scss">
@use '../styles/foundations' as *;

.projects {
  background: $color-bg;
  padding-block: $section-padding;

  &__inner {
    @include container;
  }

  &__header {
    max-width: 560px;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;

    h2 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    p {
      color: $color-text-muted;
      line-height: 1.75;
    }
  }

  &__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;

    @include respond-to('md') {
      grid-template-columns: repeat(2, 1fr);
    }

    @include respond-to('lg') {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  &__card {
    border-radius: $radius-md;
    overflow: hidden;
    border: 1px solid $color-border;
    background: $color-bg-card;
    transition: box-shadow $transition, transform $transition;

    &:hover {
      box-shadow: $shadow-md;
      transform: translateY(-3px);
    }
  }

  &__card-img {
    position: relative;
    overflow: hidden;

    img {
      width: 100%;
      aspect-ratio: 4/3;
      object-fit: cover;
      transition: transform 0.35s ease;
    }

    &:hover img {
      transform: scale(1.04);
    }
  }

  &__card-tag {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: white;
    background: $color-accent;
    padding: 0.25rem 0.625rem;
    border-radius: $radius-pill;
  }

  &__card-info {
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;

    p {
      font-size: 0.9rem;
      font-weight: 600;
      color: $color-text;
      line-height: 1.4;
    }
  }

  &__card-location {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: $color-text-subtle;
    font-weight: 500;
  }

  &__cta {
    margin-top: 3rem;
    display: flex;
    justify-content: center;
  }
}
</style>
