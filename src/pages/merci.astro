---
import Layout from '../layouts/Layout.astro'
import Nav from '../components/Nav.astro'
import Footer from '../components/Footer.astro'
---

<Layout
  title="Demande reçue — Ferretti Carrelage"
  description="Votre demande de devis a bien été envoyée. Marco vous répondra sous 48h."
>
  <Nav />
  <main class="merci">
    <div class="merci__inner">
      <svg viewBox="0 0 40 40" width="52" height="52" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <polygon points="20,0 30,10 20,20 10,10" fill="#E0621C"/>
        <polygon points="30,10 40,20 30,30 20,20" fill="#2B5FA8"/>
        <polygon points="10,10 20,20 10,30 0,20" fill="#D4607A"/>
        <polygon points="20,20 30,30 20,40 10,30" fill="white"/>
      </svg>
      <h1>Votre demande a bien été reçue.</h1>
      <p>
        Marco vous répondra personnellement sous 48h.
        Si votre projet est urgent, rappelez-le dans votre message.
      </p>
      <a href="/" class="btn btn--primary">Retour à l'accueil</a>
    </div>
  </main>
  <Footer />
</Layout>

<style lang="scss">
@use '../styles/foundations' as *;

.merci {
  background: $color-bg;
  padding-block: clamp(5rem, 15vw, 10rem);

  &__inner {
    @include container;
    @include flex-center;
    flex-direction: column;
    text-align: center;
    gap: 1.5rem;
    max-width: 520px;
    margin-inline: auto;

    h1 {
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      line-height: 1.2;
    }

    p {
      color: $color-text-muted;
      line-height: 1.75;
    }
  }
}
</style>
